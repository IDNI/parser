#include <type_traits>

#include "@SPEC_GENERATED_HEADER@"
#include "tgf/tgf_cli.h"

static constexpr const char* grammar_source =
R"@SPEC_DELIM@(@SPEC_GRAMMAR_SOURCE@)@SPEC_DELIM@";

static_assert(std::is_base_of_v<
	idni::tgf_repl_evaluator::parser_type,
	@SPEC_PARSER_NAME@>);

int main(int argc, char** argv) {
	auto& parser = @SPEC_PARSER_NAME@::instance();
	return idni::tgf_specialized_run(
		argc, argv, parser, "@SPEC_DISPLAY_NAME@", grammar_source);
}
